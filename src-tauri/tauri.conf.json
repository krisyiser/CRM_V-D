{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vainilla & Descanso",
  "version": "0.1.9",
  "identifier": "com.yersi.vainilladescanso",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vainilla & Descanso",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://api.qrserver.com data:; connect-src 'self' http://localhost:3000 http://localhost:3001 https://*.netlify.app https://*.supabase.co https://api.github.com https://*.loca.lt https://*.trycloudflare.com;"
    }
  },
  "plugins": {
    "opener": {},
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2QjI2OTU0NDFDQjlCNTUKUldSVm04dEJWR215TnJseUhFMDRVd1FuL1N1QXM2VXNMOSthOUltK05TSTNZczBXbGwvSTh1TmkK",
      "endpoints": [
        "https://raw.githubusercontent.com/krisyiser/CRM_V-D/main/update.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/cloudflared"
    ],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
